<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="SurfaceBase">#0E1014</Color>
            <Color x:Key="SurfaceRaised">#171A21</Color>
            <Color x:Key="SurfaceFloating">#1F232C</Color>
            <Color x:Key="SurfaceHover">#252A35</Color>
            <Color x:Key="DividerColor">#262A33</Color>
            <Color x:Key="TextPrimary">#F2F4F8</Color>
            <Color x:Key="TextSecondary">#A5ADBE</Color>
            <Color x:Key="TextTertiary">#6B7385</Color>
            <Color x:Key="AccentPrimary">#7C9CFF</Color>
            <Color x:Key="AccentGlow">#5C7EE6</Color>
            <Color x:Key="GateOpen">#3DDC97</Color>
            <Color x:Key="GateClosed">#4A5266</Color>
            <Color x:Key="WarnColor">#FFB347</Color>
            <Color x:Key="ErrorColor">#FF5C7A</Color>

            <SolidColorBrush x:Key="SurfaceBaseBrush"     Color="{ThemeResource SurfaceBase}" />
            <SolidColorBrush x:Key="SurfaceRaisedBrush"   Color="{ThemeResource SurfaceRaised}" />
            <SolidColorBrush x:Key="SurfaceFloatingBrush" Color="{ThemeResource SurfaceFloating}" />
            <SolidColorBrush x:Key="SurfaceHoverBrush"    Color="{ThemeResource SurfaceHover}" />
            <SolidColorBrush x:Key="DividerBrush"         Color="{ThemeResource DividerColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{ThemeResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{ThemeResource TextSecondary}" />
            <SolidColorBrush x:Key="TextTertiaryBrush"    Color="{ThemeResource TextTertiary}" />
            <SolidColorBrush x:Key="AccentPrimaryBrush"   Color="{ThemeResource AccentPrimary}" />
            <SolidColorBrush x:Key="GateOpenBrush"        Color="{ThemeResource GateOpen}" />
            <SolidColorBrush x:Key="GateClosedBrush"      Color="{ThemeResource GateClosed}" />
            <SolidColorBrush x:Key="WarnBrush"            Color="{ThemeResource WarnColor}" />
            <SolidColorBrush x:Key="ErrorBrush"           Color="{ThemeResource ErrorColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
