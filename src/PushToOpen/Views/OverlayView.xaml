<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PushToOpen.Views.OverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:PushToOpen.Controls">

    <Border x:Name="OverlayRoot"
            Background="#EE161922"
            BorderBrush="#332E3343"
            BorderThickness="1"
            CornerRadius="14">

        <Grid Margin="14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/VMic.ico" Width="14" Height="14" />
                    <TextBlock Text="PushToOpen"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <!-- Mic mute glyph: E720 = mic, E74F = mic-off -->
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Text="{x:Bind ViewModel.IsMuted, Mode=OneWay, Converter={StaticResource MicGlyph}}"
                               Foreground="{x:Bind ViewModel.IsMuted, Mode=OneWay, Converter={StaticResource MicBrush}}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               ToolTipService.ToolTip="Microphone state" />
                    <Border Padding="7,3" CornerRadius="10"
                            Background="{ThemeResource SurfacePanelBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{x:Bind ViewModel.IsGateOpen, Mode=OneWay, Converter={StaticResource GateBrush}}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.IsGateOpen, Mode=OneWay, Converter={StaticResource GateLabel}}"
                                       FontFamily="Segoe UI Variable Small"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource IconButton}"
                            ToolTipService.ToolTip="Lock/unlock overlay position"
                            Command="{x:Bind ViewModel.ToggleLockCommand}"
                            Padding="6"
                            Content="{x:Bind ViewModel.IsLocked, Mode=OneWay, Converter={StaticResource LockGlyph}}"
                            Foreground="{x:Bind ViewModel.IsLocked, Mode=OneWay, Converter={StaticResource LockBrush}}" />
                </StackPanel>
            </Grid>

            <ctrl:VuMeter Grid.Row="1" Margin="0,10,0,0"
                          Level="{x:Bind ViewModel.RmsNormalized, Mode=OneWay}"
                          Threshold="{x:Bind ViewModel.ThresholdNormalized, Mode=OneWay}"
                          IsActive="{x:Bind ViewModel.IsGateOpen, Mode=OneWay}" />

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <TextBlock Text="MIC"
                           FontFamily="Segoe UI Variable Small"
                           FontSize="10" FontWeight="SemiBold" CharacterSpacing="80"
                           Foreground="{ThemeResource TextTertiaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right"
                           Text="{x:Bind ViewModel.RmsDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
