<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PushToOpen.Views.MainShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:PushToOpen.ViewModels"
    xmlns:ctrl="using:PushToOpen.Controls"
    xmlns:conv="using:PushToOpen.Utilities">

    <Grid x:Name="RootGrid" Background="{ThemeResource SurfaceBaseBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Title bar -->
        <Grid x:Name="AppTitleBar" Grid.ColumnSpan="2" Background="Transparent">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center" Spacing="12">
                <Image Source="ms-appx:///Assets/VMic.ico" Width="22" Height="22" />
                <TextBlock Text="PushToOpen"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{ThemeResource SurfaceRaisedBrush}"
                BorderBrush="{ThemeResource DividerBrush}"
                BorderThickness="0,1,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Workspace identity -->
                <Border Margin="14,14,14,10" Padding="14,12"
                        Background="{ThemeResource SurfaceFloatingBrush}"
                        BorderBrush="{ThemeResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="INPUT DEVICE" Style="{StaticResource LabelText}" />
                        <TextBlock Text="{x:Bind ViewModel.Home.DeviceName, Mode=OneWay}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Margin="10,4,10,0" Spacing="3">
                    <ToggleButton Style="{StaticResource NavButton}"
                                  IsChecked="{x:Bind ViewModel.ActiveSection, Mode=TwoWay, Converter={StaticResource SectionEq}, ConverterParameter=home}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE9F5;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Live" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource NavButton}"
                                  IsChecked="{x:Bind ViewModel.ActiveSection, Mode=TwoWay, Converter={StaticResource SectionEq}, ConverterParameter=audio}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE720;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Audio" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource NavButton}"
                                  IsChecked="{x:Bind ViewModel.ActiveSection, Mode=TwoWay, Converter={StaticResource SectionEq}, ConverterParameter=hotkey}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE92E;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Hotkey" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource NavButton}"
                                  IsChecked="{x:Bind ViewModel.ActiveSection, Mode=TwoWay, Converter={StaticResource SectionEq}, ConverterParameter=overlay}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE7C4;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Overlay" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource NavButton}"
                                  IsChecked="{x:Bind ViewModel.ActiveSection, Mode=TwoWay, Converter={StaticResource SectionEq}, ConverterParameter=prefs}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE713;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Preferences" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <!-- Status panel -->
                <Border Grid.Row="2"
                        Margin="14,0,14,14" Padding="14,12"
                        Background="{ThemeResource SurfaceFloatingBrush}"
                        BorderBrush="{ThemeResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="STATUS" Style="{StaticResource LabelText}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateBrush}}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateLabel}}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="KEY" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.Hotkey.KeyDisplay, Mode=OneWay}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="{ThemeResource AccentPrimaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content area -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{ThemeResource SurfaceBaseBrush}"
                BorderBrush="{ThemeResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <ScrollViewer Padding="36,28,36,32" VerticalScrollBarVisibility="Auto">
                <Grid>

                    <!-- LIVE -->
                    <StackPanel Spacing="22"
                                Visibility="{x:Bind ViewModel.ActiveSection, Mode=OneWay, Converter={StaticResource SectionEq}, ConverterParameter=home}">
                        <Grid>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Live monitor" Style="{StaticResource DisplayLargeText}" />
                                <TextBlock Text="Real-time microphone level, gate state, and threshold calibration."
                                           Style="{StaticResource BodyText}" />
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Padding="12,7" CornerRadius="20"
                                    Background="{ThemeResource SurfaceFloatingBrush}"
                                    BorderBrush="{ThemeResource DividerBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="8" Height="8" CornerRadius="4"
                                            Background="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateBrush}}"
                                            VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateLabel}}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="20">
                                <Grid>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="MIC LEVEL" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{x:Bind ViewModel.Home.RmsDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                                   Style="{StaticResource BigMetricText}" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Spacing="3">
                                        <TextBlock Text="PEAK" Style="{StaticResource LabelText}" HorizontalAlignment="Right" />
                                        <TextBlock Text="{x:Bind ViewModel.Home.PeakDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                                   Style="{StaticResource MetricText}"
                                                   FontSize="16"
                                                   Foreground="{ThemeResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>

                                <ctrl:VuMeter Level="{x:Bind ViewModel.Home.RmsNormalized, Mode=OneWay}"
                                              Threshold="{x:Bind ViewModel.Home.ThresholdNormalized, Mode=OneWay}"
                                              IsActive="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay}" />

                                <Grid Margin="0,-6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="-60" Style="{StaticResource LabelText}" Opacity="0.5" />
                                    <TextBlock Grid.Column="1" Text="-45" Style="{StaticResource LabelText}" Opacity="0.5" />
                                    <TextBlock Grid.Column="2" Text="-30" Style="{StaticResource LabelText}" Opacity="0.5" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="-15" Style="{StaticResource LabelText}" Opacity="0.5" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="0" Style="{StaticResource LabelText}" Opacity="0.5" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="THRESHOLD" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="Mic level required to engage push-to-talk"
                                                   Style="{StaticResource BodyText}" FontSize="12" />
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.Home.ThresholdDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                               Style="{StaticResource BigMetricText}"
                                               Foreground="{ThemeResource AccentPrimaryBrush}" />
                                </Grid>
                                <Slider Minimum="-60" Maximum="0" StepFrequency="0.5"
                                        Value="{x:Bind ViewModel.Home.ThresholdDb, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Style="{StaticResource GhostButton}" Content="Whisper"
                                            Command="{x:Bind ViewModel.Home.ApplyPresetCommand}" CommandParameter="whisper" />
                                    <Button Style="{StaticResource GhostButton}" Content="Soft"
                                            Command="{x:Bind ViewModel.Home.ApplyPresetCommand}" CommandParameter="soft" />
                                    <Button Style="{StaticResource GhostButton}" Content="Normal"
                                            Command="{x:Bind ViewModel.Home.ApplyPresetCommand}" CommandParameter="normal" />
                                    <Button Style="{StaticResource GhostButton}" Content="Loud"
                                            Command="{x:Bind ViewModel.Home.ApplyPresetCommand}" CommandParameter="loud" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Text="&#xE9F5;" FontSize="14"
                                                   Foreground="{ThemeResource AccentPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Detection" Style="{StaticResource TitleText}" />
                                    </StackPanel>
                                    <TextBlock Text="Continuously monitor mic level and trigger the key."
                                               Style="{StaticResource BodyText}" FontSize="12" />
                                    <ToggleSwitch IsOn="{x:Bind ViewModel.Home.Enabled, Mode=TwoWay}"
                                                  OffContent="Disabled" OnContent="Enabled" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource Card}">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Text="&#xE74F;" FontSize="14"
                                                   Foreground="{ThemeResource AccentPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Mute" Style="{StaticResource TitleText}" />
                                    </StackPanel>
                                    <TextBlock Text="Force the gate closed regardless of mic level."
                                               Style="{StaticResource BodyText}" FontSize="12" />
                                    <ToggleSwitch IsOn="{x:Bind ViewModel.Home.Muted, Mode=TwoWay}"
                                                  OffContent="Live" OnContent="Muted" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- AUDIO -->
                    <StackPanel Spacing="22"
                                Visibility="{x:Bind ViewModel.ActiveSection, Mode=OneWay, Converter={StaticResource SectionEq}, ConverterParameter=audio}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Audio" Style="{StaticResource DisplayLargeText}" />
                            <TextBlock Text="Pick an input device, set the noise floor, and trim gain."
                                       Style="{StaticResource BodyText}" />
                        </StackPanel>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE720;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Input device" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.Audio.Devices}"
                                              SelectedItem="{x:Bind ViewModel.Audio.SelectedDevice, Mode=TwoWay}" />
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                            Content="Refresh"
                                            Command="{x:Bind ViewModel.Audio.RefreshDevicesCommand}" />
                                </Grid>
                                <TextBlock Style="{StaticResource BodyText}"
                                           Text="{x:Bind ViewModel.Audio.ErrorMessage, Mode=OneWay}"
                                           Foreground="{ThemeResource ErrorBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <Grid>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="NOISE GATE FLOOR" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="Levels below this are zeroed before RMS averaging."
                                                   Style="{StaticResource BodyText}" FontSize="12" />
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.Audio.NoiseGateDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                               Style="{StaticResource BigMetricText}"
                                               Foreground="{ThemeResource AccentPrimaryBrush}" />
                                </Grid>
                                <Slider Minimum="-80" Maximum="-20" StepFrequency="0.5"
                                        Value="{x:Bind ViewModel.Audio.NoiseGateDb, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <Grid>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="INPUT GAIN" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="Boost or attenuate the mic signal before measurement."
                                                   Style="{StaticResource BodyText}" FontSize="12" />
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.Audio.GainDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                               Style="{StaticResource BigMetricText}"
                                               Foreground="{ThemeResource AccentPrimaryBrush}" />
                                </Grid>
                                <Slider Minimum="-12" Maximum="24" StepFrequency="0.5"
                                        Value="{x:Bind ViewModel.Audio.GainDb, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Hear yourself (monitor) -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE7F6;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Hear yourself" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource BodyText}" FontSize="12"
                                           Text="Plays your mic back through your default output. Use HEADPHONES — speakers will cause feedback. Lets you hear what the noise suppression is doing." />
                                <ToggleSwitch Header="Enable mic monitoring"
                                              IsOn="{x:Bind ViewModel.Audio.MonitorEnabled, Mode=TwoWay}"
                                              OffContent="Off" OnContent="Listening" />
                                <Grid>
                                    <TextBlock Text="MONITOR LEVEL" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.Audio.MonitorGainDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                                               Style="{StaticResource MetricText}"
                                               Foreground="{ThemeResource AccentPrimaryBrush}" />
                                </Grid>
                                <Slider Minimum="-30" Maximum="6" StepFrequency="0.5"
                                        Value="{x:Bind ViewModel.Audio.MonitorGainDb, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Noise suppression -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE9CE;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Voice noise suppression" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource BodyText}" FontSize="12"
                                           Text="Spectral noise reduction (FFT-based). Removes steady-state hiss, fan and room tone from the THRESHOLD detection + the Hear-yourself monitor — apps like Discord still receive your raw mic. For system-wide neural NS, use Discord's built-in Krisp or NVIDIA Broadcast." />
                                <ToggleSwitch Header="Enable noise suppression"
                                              IsOn="{x:Bind ViewModel.Audio.NoiseSuppressionEnabled, Mode=TwoWay}"
                                              OffContent="Off" OnContent="Active" />
                                <Grid>
                                    <TextBlock Text="STRENGTH" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.Audio.NoiseSuppressionStrength, Mode=OneWay}"
                                               Style="{StaticResource MetricText}"
                                               Foreground="{ThemeResource AccentPrimaryBrush}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="1" StepFrequency="0.05"
                                        Value="{x:Bind ViewModel.Audio.NoiseSuppressionStrength, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- HOTKEY -->
                    <StackPanel Spacing="22"
                                Visibility="{x:Bind ViewModel.ActiveSection, Mode=OneWay, Converter={StaticResource SectionEq}, ConverterParameter=hotkey}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Hotkey &amp; timing" Style="{StaticResource DisplayLargeText}" />
                            <TextBlock Text="Set the key PushToOpen holds and tune attack / release envelope."
                                       Style="{StaticResource BodyText}" />
                        </StackPanel>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE92E;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Bound key" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{ThemeResource SurfacePanelBrush}"
                                            BorderBrush="{ThemeResource DividerBrightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10" Padding="22,16">
                                        <TextBlock Text="{x:Bind ViewModel.Hotkey.KeyDisplay, Mode=OneWay}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Button Style="{StaticResource AccentButton}" Content="Rebind…"
                                                Command="{x:Bind ViewModel.Hotkey.StartCaptureCommand}"
                                                Visibility="{x:Bind ViewModel.Hotkey.IsCapturing, Mode=OneWay, Converter={StaticResource InvBoolToVis}}" />
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Text="Press any key…  (Esc cancels)"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind ViewModel.Hotkey.IsCapturing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel"
                                                Command="{x:Bind ViewModel.Hotkey.CancelCaptureCommand}"
                                                Visibility="{x:Bind ViewModel.Hotkey.IsCapturing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE74F;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Mute toggle hotkey" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource BodyText}" FontSize="12"
                                           Text="Bind a global key that flips Mute on/off without opening the app. Works while any window is focused." />
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{ThemeResource SurfacePanelBrush}"
                                            BorderBrush="{ThemeResource DividerBrightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10" Padding="22,16">
                                        <TextBlock Text="{x:Bind ViewModel.Hotkey.MuteToggleKeyDisplay, Mode=OneWay}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Button Style="{StaticResource AccentButton}" Content="Bind…"
                                                Command="{x:Bind ViewModel.Hotkey.StartCaptureMuteToggleCommand}"
                                                Visibility="{x:Bind ViewModel.Hotkey.IsCapturingMuteToggle, Mode=OneWay, Converter={StaticResource InvBoolToVis}}" />
                                        <Button Style="{StaticResource GhostButton}" Content="Clear"
                                                Command="{x:Bind ViewModel.Hotkey.ClearMuteToggleCommand}"
                                                Visibility="{x:Bind ViewModel.Hotkey.IsCapturingMuteToggle, Mode=OneWay, Converter={StaticResource InvBoolToVis}}" />
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   Text="Press any key…  (Esc cancels)"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind ViewModel.Hotkey.IsCapturingMuteToggle, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel"
                                                Command="{x:Bind ViewModel.Hotkey.CancelCaptureCommand}"
                                                Visibility="{x:Bind ViewModel.Hotkey.IsCapturingMuteToggle, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="18">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Text="&#xE916;" FontSize="14"
                                               Foreground="{ThemeResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Envelope timing" Style="{StaticResource TitleText}" />
                                </StackPanel>
                                <Grid ColumnSpacing="16" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Attack (ms)" Style="{StaticResource LabelText}" />
                                    <TextBlock Grid.Column="1" Text="Release (ms)" Style="{StaticResource LabelText}" />
                                    <TextBlock Grid.Column="2" Text="Debounce (ms)" Style="{StaticResource LabelText}" />

                                    <muxc:NumberBox Grid.Row="1" Minimum="0" Maximum="500"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{x:Bind ViewModel.Hotkey.AttackMs, Mode=TwoWay}" />
                                    <muxc:NumberBox Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="2000"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{x:Bind ViewModel.Hotkey.ReleaseMs, Mode=TwoWay}" />
                                    <muxc:NumberBox Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="500"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{x:Bind ViewModel.Hotkey.DebounceMs, Mode=TwoWay}" />
                                </Grid>
                                <TextBlock Style="{StaticResource BodyText}" FontSize="12"
                                           Text="Attack — mic must stay above threshold this long before the key engages. Release — must stay below for this long before key releases. Debounce — minimum interval between state flips." />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- OVERLAY -->
                    <StackPanel Spacing="22"
                                Visibility="{x:Bind ViewModel.ActiveSection, Mode=OneWay, Converter={StaticResource SectionEq}, ConverterParameter=overlay}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Overlay" Style="{StaticResource DisplayLargeText}" />
                            <TextBlock Text="Compact floating monitor — keeps mic level visible while the main window is minimized."
                                       Style="{StaticResource BodyText}" />
                        </StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <ToggleSwitch Header="Show floating overlay"
                                              IsOn="{x:Bind ViewModel.Overlay.ShowOverlay, Mode=TwoWay}" />
                                <ToggleSwitch Header="Always on top"
                                              IsOn="{x:Bind ViewModel.Overlay.AlwaysOnTop, Mode=TwoWay}" />
                                <ToggleSwitch Header="Lock position (prevents dragging)"
                                              IsOn="{x:Bind ViewModel.Overlay.IsLocked, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- PREFS -->
                    <StackPanel Spacing="22"
                                Visibility="{x:Bind ViewModel.ActiveSection, Mode=OneWay, Converter={StaticResource SectionEq}, ConverterParameter=prefs}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Preferences" Style="{StaticResource DisplayLargeText}" />
                            <TextBlock Text="System integration and startup behavior."
                                       Style="{StaticResource BodyText}" />
                        </StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel Spacing="14">
                                <ToggleSwitch Header="Minimize to system tray (not taskbar)"
                                              IsOn="{x:Bind ViewModel.Preferences.MinimizeToTray, Mode=TwoWay}" />
                                <ToggleSwitch Header="Start minimized"
                                              IsOn="{x:Bind ViewModel.Preferences.StartMinimized, Mode=TwoWay}" />
                                <ToggleSwitch Header="Launch on Windows startup"
                                              IsOn="{x:Bind ViewModel.Preferences.LaunchOnStartup, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{ThemeResource SurfaceRaisedBrush}"
                BorderBrush="{ThemeResource DividerBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,9">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Width="7" Height="7" CornerRadius="3.5"
                            Background="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateBrush}}"
                            VerticalAlignment="Center" />
                    <TextBlock FontFamily="Segoe UI Variable Small" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               Text="{x:Bind ViewModel.Home.IsGateOpen, Mode=OneWay, Converter={StaticResource GateLabel}}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           FontFamily="Segoe UI Variable Small" FontSize="11"
                           Foreground="{ThemeResource TextTertiaryBrush}"
                           Text="{x:Bind ViewModel.Home.DeviceName, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="320" />

                <TextBlock Grid.Column="2" HorizontalAlignment="Center"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           Foreground="{ThemeResource TextTertiaryBrush}"
                           Text="{x:Bind ViewModel.Home.RmsDb, Mode=OneWay, Converter={StaticResource FormatDb}}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="KEY" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                    <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentPrimaryBrush}"
                               Text="{x:Bind ViewModel.Hotkey.KeyDisplay, Mode=OneWay}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
