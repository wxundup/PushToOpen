<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PushToOpen.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PushToOpen.Views"
    xmlns:tray="using:H.NotifyIcon"
    Title="PushToOpen">

    <Grid>
        <views:MainShellView x:Name="Shell" />
        <tray:TaskbarIcon x:Name="TrayIcon"
                          ToolTipText="PushToOpen"
                          IconSource="ms-appx:///Assets/tray.ico"
                          NoLeftClickDelay="True"
                          LeftClickCommand="{x:Bind ShowFromTrayCommand}">
            <tray:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open PushToOpen" Click="OnTrayShow" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutSubItem Text="Threshold preset">
                        <MenuFlyoutItem Text="Whisper  (-50 dB)" Click="OnTrayPreset" Tag="-50" />
                        <MenuFlyoutItem Text="Soft  (-42 dB)"    Click="OnTrayPreset" Tag="-42" />
                        <MenuFlyoutItem Text="Normal  (-34 dB)"  Click="OnTrayPreset" Tag="-34" />
                        <MenuFlyoutItem Text="Loud  (-24 dB)"    Click="OnTrayPreset" Tag="-24" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="OnTrayExit" />
                </MenuFlyout>
            </tray:TaskbarIcon.ContextFlyout>
        </tray:TaskbarIcon>
    </Grid>
</Window>
